---
import type { Trend } from "@lib/exchange-rate";

type Props = {
  trend: Trend;
  mascotLabel: string;
};

const { trend, mascotLabel } = Astro.props;

const trendLabelMap = {
  up: "Subiendo sabroso",
  down: "Bajando rico",
  stable: "Ni fu ni fa",
} as const;
---

<section class="glass-card soft-grid relative overflow-hidden rounded-[2rem] p-4 md:p-5 enter-rise" data-hero-root>
  <div class="mb-3 flex items-center justify-between gap-3">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Hero en canvas</p>
      <h2 class="text-lg font-black tracking-tight text-slate-900 md:text-xl" data-hero-label>{mascotLabel}</h2>
    </div>
    <span
      class="trend-badge rounded-full px-4 py-2 text-sm font-black uppercase tracking-[0.18em]"
      data-hero-trend
      data-trend={trend}
    >
      {trendLabelMap[trend]}
    </span>
  </div>

  <div class="relative min-h-[280px] overflow-hidden rounded-[1.5rem] bg-white/40 md:min-h-[340px]">
    <canvas
      class="block h-[280px] w-full md:h-[340px]"
      data-canvas-hero
      data-trend={trend}
      aria-label={mascotLabel}
      role="img"
    ></canvas>

    <div
      class="pointer-events-none absolute inset-x-3 bottom-3 rounded-2xl bg-white/70 px-3 py-2 text-xs text-slate-600 backdrop-blur md:inset-x-4 md:bottom-4 md:px-4 md:py-3 md:text-sm"
      data-hero-caption
    >
      Un solo canvas responsivo. La mascotilla reacciona a la vara en tiempo real.
    </div>
  </div>
</section>

<script>
  import { createHeroScene } from "@lib/canvas/hero-scene";

  const heroRoot = document.querySelector("[data-hero-root]");

  if (heroRoot instanceof HTMLElement) {
    const canvas = heroRoot.querySelector("[data-canvas-hero]");
    const label = heroRoot.querySelector("[data-hero-label]");
    const trendBadge = heroRoot.querySelector("[data-hero-trend]");
    const caption = heroRoot.querySelector("[data-hero-caption]");

    const trendLabelMap = {
      up: "Subiendo sabroso",
      down: "Bajando rico",
      stable: "Ni fu ni fa",
    };

    let cleanup = () => undefined;

    const mountHero = (nextTrend, mascotLabel, nextCaption, intensity = "mild") => {
      if (!(canvas instanceof HTMLCanvasElement)) {
        return;
      }

      cleanup();
      canvas.dataset.trend = nextTrend;
      canvas.dataset.intensity = intensity;
      canvas.setAttribute("aria-label", mascotLabel);
      cleanup = createHeroScene({ canvas, trend: nextTrend, intensity });

      if (label instanceof HTMLElement) {
        label.textContent = mascotLabel;
      }

      if (trendBadge instanceof HTMLElement) {
        trendBadge.textContent = trendLabelMap[nextTrend];
        trendBadge.dataset.trend = nextTrend;
      }

      if (caption instanceof HTMLElement) {
        caption.textContent = nextCaption;
      }
    };

    const initialTrend = canvas instanceof HTMLCanvasElement ? canvas.dataset.trend : undefined;

    if (initialTrend === "up" || initialTrend === "down" || initialTrend === "stable") {
      mountHero(initialTrend, canvas.getAttribute("aria-label") ?? "Mascota del tipo de cambio", "Un solo canvas responsivo. La mascotilla reacciona a la vara en tiempo real.");
    }

    window.addEventListener("dolar-mood:update", (event) => {
      if (!(event instanceof CustomEvent)) {
        return;
      }

      const detail = event.detail;

      if (!detail || (detail.trend !== "up" && detail.trend !== "down" && detail.trend !== "stable")) {
        return;
      }

      mountHero(detail.trend, detail.mascotLabel, detail.heroCaption, detail.intensity);
    });

    window.addEventListener("astro:before-swap", () => cleanup(), { once: true });
  }
</script>
